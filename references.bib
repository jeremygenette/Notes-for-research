@incollection{duanmuVowelHeight2016,
  title = {Vowel Height},
  booktitle = {A Theory of Phonological Features},
  author = {Duanmu, San},
  editor = {Duanmu, San},
  year = 2016,
  month = mar,
  publisher = {Oxford University Press},
  doi = {10.1093/acprof:oso/9780199664962.003.0004},
  urldate = {2025-03-17},
  abstract = {This chapter takes a close look at vowel height, which is the only phonetic dimension that has a three-way contrast. It is found that all contrasts among basic vowels in UPSID and P-base can be represented in a two-height system, which uses four binary features [back], [high], [round], and [ATR], giving a total of sixteen basic vowels. In addition, an examination of all sound classes in P-base shows that there is no need for the feature [low]. Two other problems are also discussed: the representation of [tense] in English and step-raising of vowels. It is concluded that a two-height vowel system is a viable and simpler alternative to traditional theories of vowel features.},
  isbn = {978-0-19-966496-2},
  langid = {english}
}

@article{duckworth2011,
  title = {Improving the Consistency of Formant Measurement},
  author = {Duckworth, M. and McDougall, K. and {de Jong}, G. and Shockey, L.},
  year = 2011,
  journal = {International Journal of Speech Language and the Law},
  volume = {18},
  number = {1},
  pages = {35--51},
  doi = {10.1558/ijsll.v18i1.35},
  abstract = {This study examines the inter-analyst robustness of formant frequency (F) measurements before and after agreeing a common measurement procedure. Three laboratories used the latest available version of the same formant extraction software to extract F1, F2 and F3 values from the same sets of high quality audio recordings of six repetitions of read utterances containing six target monophthongs, /i:, \ae, a:, c;, {$\upsilon$},{$\mu$}The subjects were two sets of twenty British males with a similar accent profile. Results are presented which show the extent to which analyst, methodology, vowel, and speaker affect the consistency of the values extracted. Agreeing the methodology reduced the extent of variation among the results from the three laboratories as might be expected. However, there remained some differences and even occasionally a greater disparity among the measurements. The paper suggests sources of these differences and makes proposals for a consistent logging of settings and times used when extracting F values. Further, it recommends that practitioners aim to establish an agreed protocol for forensic analysis of formants to facilitate the validation of evidence.},
  langid = {english},
  keywords = {forensic phonetic evidence,forensic phonetic report-writing,formant frequencies,formant measurement,inter-analyst reliability}
}

