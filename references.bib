@article{genetteIntrinsicVowelFundamental2025,
  title = {Intrinsic Vowel Fundamental Frequency in Children with and without Hearing Impairment},
  author = {Genette, J{\'e}r{\'e}my and Gillis, Steven and Verhoeven, Jo},
  year = 2025,
  journal = {Folia Phoniatrica Et Logopaedica},
  volume = {77},
  number = {4},
  pages = {347--361},
  issn = {1021-7762},
  doi = {10.1159/000543426},
  urldate = {2026-07-01},
  abstract = {Introduction: It is well established that high vowels tend to have a higher F0 than low vowels, a phenomenon known as intrinsic vowel F0 (IF0). However, the underlying cause of IF0 remains debated. Previous research suggests that IF0 is entirely of physiological origin, while other research indicates that it is acquired to enhance perceptual contrasts between vowels. Methods: This study explored the impact of hearing loss on IF0 in six-year-old children, both with and without hearing impairment. The Belgian Dutch vowels produced by the children in both groups during a (non-)word repetition task were acoustically analysed for F0. Results: The main result was that all children presented IF0. Although IF0 was not significantly different between children with and without hearing impairment, there was a trend towards a smaller IF0 in the hearing-impaired group. Conclusion: In conclusion, while the results of this study support the physiological hypothesis, they also suggest a potential role for perceptual factors in shaping IF0. The results were interpreted in relation to the combined potential effects of speech organ physiology and perception on IF0.},
  langid = {english},
  keywords = {MetadataHunter: Update Failed},
  file = {/Users/jeremy-ua/Zotero/storage/GZ5ZNCKR/genette et al_2025_intrinsic vowel fundamental frequency in children with and without hearing.pdf;/Users/jeremy-ua/Zotero/storage/LT343TW5/Genette et al. - 2025 - Intrinsic vowel fundamental frequency in children with and without hearing impairment.pdf}
}

