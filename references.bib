@inproceedings{bonaHistoryChildLanguage2024,
  title = {The History of Child Language Research in {{ICPhS}} between 1932 and 2023},
  booktitle = {Sixth {{International Workshop}} on the {{History}} of {{Speech Communication Research}} ({{HSCR}} 2024)},
  author = {B{\'o}na, Judit and Mur{\'a}nyi, Sarolta},
  year = 2024,
  month = sep,
  pages = {126--135},
  publisher = {ISCA},
  doi = {10.21437/HSCR.2024-17},
  urldate = {2025-02-05},
  abstract = {Examination of the age-specific features of speech, including child language and speech, is an important area of phonetic research. In the present study, we investigate research papers on child language that were published at ICPhS congresses between 1932 and 2023. Results show that, although child language research is becoming increasingly frequent at ICPhS congresses, it still quite underrepresented. The age and number of children included in the studies varies widely. We found papers about 52 different languages as the mother tongue of the children, of which the studies focus mostly on English, followed by the other Indo-European languages. Among the non-Indo-European languages, there were 28 different languages from 14 language families. There was a wide variety of covered topics, dealing with acoustic features of both segmental and suprasegmental levels of child speech, and the development of speech perception. Predominantly monolingual children with typical development were examined, but we also found articles on bilingual, multilingual and children with atypical language development. Overall, there is still work to be carried out in order to better represent the phonetic features of language acquisition in ICPhS congresses. A similar overview is needed to understand the history of the methodology of child language research.},
  langid = {english},
  file = {/Users/jeremy-ua/Zotero/storage/4GSRHWG5/Bóna and Murányi - 2024 - The history of child language research in ICPhS between 1932 and 2023.pdf}
}

